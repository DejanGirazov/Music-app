generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Artist {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  songs     Song[]
  createdAt DateTime @default(now())
}

model Song {
  id         Int      @id @default(autoincrement())
  title      String
  artist     Artist   @relation(fields: [artistId], references: [id])
  artistId   Int
  uploaderId  Int
  uploader    User     @relation(fields: [uploaderId], references: [id])
  fileKey    String   // R2 object key, for deletes/updates
  duration   Int?     // seconds
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([artistId])
}
enum Role {
  USER
  ADMIN
}
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  fullName     String   
  passwordHash String
  role         Role     @default(USER)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  songs        Song[]
}